# CV Hunter — Variables d'Entorn
# Copia aquest fitxer a .env i omple els valors

# Seguretat
SECRET_KEY=canvia-aquesta-clau-aleatoria-llarga-en-produccio
APP_ENV=development

# Base de dades PostgreSQL
DATABASE_URL=postgresql+asyncpg://cvhunter:cvhunter@localhost:5432/cvhunter

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# CORS (URLs del frontend)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Free Trial
FREE_TRIAL_DAYS=30
FREE_TRIAL_CV_LIMIT=50
